# ============================================================================
# Production environment template for the Docker deployment.
#
# Copy this to `.env` (same directory as docker-compose.yml) and fill in every
# placeholder marked CHANGE_ME before running `docker compose up -d`. This file
# itself is never read by the app or baked into the image (see .dockerignore) —
# it exists only as the template you copy from.
# ============================================================================

APP_NAME=Wejha
APP_ENV=production
# Generate with: docker compose run --rm app php artisan key:generate --show
APP_KEY=CHANGE_ME
APP_DEBUG=false
# Public URL of the deployed site, e.g. https://admin.wejha.org.ly
APP_URL=CHANGE_ME
APP_TIMEZONE=Africa/Tripoli

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logs go to the container's stdout/stderr (docker compose logs -f app) rather than
# a log file inside the container, matching standard container logging practice.
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# --- Database ---------------------------------------------------------------
# DB_HOST must stay "db" — that's the docker-compose service name on the internal
# network, not a real hostname.
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=wejha
DB_USERNAME=wejha
DB_PASSWORD=CHANGE_ME_use_a_long_random_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Required once you serve over HTTPS in production:
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Mail (SMTP) --------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME
MAIL_PORT=465
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=CHANGE_ME
MAIL_FROM_NAME="${APP_NAME}"

EMAIL_USER=CHANGE_ME
EMAIL_PASSWORD=CHANGE_ME

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Firebase service-account JSON must be placed at storage/app/firebase-auth.json
# inside the storage_public volume (or baked in via a build secret) — never commit
# the real file to git.
FIREBASE_CREDENTIALS=storage/app/firebase-auth.json

# --- Compose-only settings ----------------------------------------------------
# Host port the app is published on (docker-compose.yml maps this -> container 8080).
APP_PORT=80
