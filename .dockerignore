# Dependencies (installed fresh inside the image)
/vendor
/node_modules

# Never bake secrets or local env into the image
.env
.env.*
!.env.example
!.env.docker.example
storage/app/firebase-auth.json

# VCS
.git
.gitignore
.gitattributes

# Local dev / IDE
.idea
.vscode
*.log

# Laravel local runtime state — regenerated at container start / at runtime, not
# meaningful to ship inside the image build context
/storage/*.key
/storage/app/public/*
!/storage/app/public/.gitignore
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/logs/*
!/storage/framework/cache/data/.gitignore
!/storage/framework/sessions/.gitignore
!/storage/framework/testing/.gitignore
!/storage/framework/views/.gitignore
!/storage/logs/.gitignore
/storage/fonts/*
!/storage/fonts/.gitignore
/storage/app/dompdf-temp/*
!/storage/app/dompdf-temp/.gitignore
/bootstrap/cache/*.php

# Tests / dev tooling not needed at runtime
/tests
phpunit.xml
.phpunit.result.cache

# Docker's own files (no need to recurse into themselves)
docker-compose*.yml
Dockerfile*
.dockerignore

# Misc
README.md
DOCKER.md
*.md
!resources/**/*.md
